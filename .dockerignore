# Docker build context excludes.
#
# The image only needs what the Dockerfile COPYs: requirements.lock,
# pyproject.toml, README.md, src/, inference.py, configs/, templates/,
# resources/. Everything below is either mounted at runtime (model -> /opt/ml/model,
# data -> /input, outputs -> /output) or dev-only, so keep it out of the build
# context — a smaller context means faster builds and no risk of baking weights
# or data into the image.

# --- Large local artifacts (mounted at runtime, never baked in) ---
model/
data/
data_subset/
test/
*.tar.gz
*.zip
*.sqsh

# --- Version control ---
.git/
.gitignore
.gitattributes

# --- Python caches / build outputs ---
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.venv/
venv/
.venv-dl/

# --- Tooling caches ---
.ruff_cache/
.pytest_cache/
.mypy_cache/
.hydra/
*.log

# --- Dev-only sources not needed at runtime (not COPYd by the Dockerfile) ---
docs/
scripts/
tests/
notebooks/

# --- Secrets / local config ---
.env
.env.example
.syncignore
.claude/

# --- Maintainer-only cluster assets ---
Makefile.cluster
_cluster/

# --- Editor / OS cruft ---
.DS_Store
.idea/
.vscode/
