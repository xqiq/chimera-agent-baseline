# Copy to .env and fill in your values.

# HuggingFace token — required for downloading gated models (Gemma 4, etc.)
# Get yours at https://huggingface.co/settings/tokens.
HF_TOKEN=

# Optional: only needed when running with provider: openai against a real
# cloud endpoint (e.g. OpenAI's hosted API). Local llama.cpp / vLLM-OpenAI
# servers usually accept any non-empty key, or none.
# OPENAI_API_KEY=

# Bearer token for a self-hosted OpenAI-compatible server (llama.cpp,
# vLLM OpenAI, etc.). Leave blank if your server has --api-key disabled.
# Used by configs/experiment/qwen_local.yaml via api_key_env: LLAMA_API_KEY.
# LLAMA_API_KEY=
